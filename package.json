{
  "name": "marinara-engine",
  "private": true,
  "version": "1.6.1",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "node scripts/run-vite.mjs",
    "docs:dev": "node scripts/run-vite.mjs docs/developer --host 127.0.0.1 --port 4174",
    "build": "tsc -b && node scripts/run-vite.mjs build",
    "typecheck": "tsc -b",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "lint": "pnpm lint:eslint",
    "lint:all": "pnpm lint:eslint && pnpm format:check && pnpm lint:design",
    "lint:eslint": "eslint .",
    "lint:eslint:full-report": "node scripts/eslint-full-report.mjs",
    "lint:design": "impeccable detect --fast src",
    "lint:design:report": "pnpm lint:design || test $? -eq 2",
    "check:architecture": "depcruise src --config .dependency-cruiser.cjs && node scripts/check-rust-structure.mjs",
    "check:frontend": "tsc -b",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml --workspace",
    "check:rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --workspace --all-targets -- -D warnings",
    "check:rust:test": "cargo test --manifest-path src-tauri/Cargo.toml --workspace",
    "check:rust:nextest": "cargo nextest run --manifest-path src-tauri/Cargo.toml --workspace",
    "check:rust:deny": "cargo deny --manifest-path src-tauri/Cargo.toml check --config deny.toml",
    "check:rust:deps": "cargo machete src-tauri",
    "check:docs": "node scripts/check-docs.mjs",
    "check:line-endings": "node scripts/check-line-endings.mjs",
    "check:unused": "knip --no-config-hints",
    "check": "pnpm check:line-endings && pnpm check:architecture && pnpm check:frontend && pnpm check:rust && pnpm check:docs && pnpm check:unused",
    "test": "vitest run",
    "test:allow-empty": "vitest run --passWithNoTests",
    "test:ui": "pnpm build && playwright test",
    "test:ui:run": "playwright test",
    "bench:ts": "vitest bench",
    "bench:rust": "cargo bench --manifest-path src-tauri/Cargo.toml --workspace",
    "perf:lighthouse": "lhci autorun",
    "perf:size": "size-limit",
    "preview": "node scripts/run-vite.mjs preview",
    "tauri": "node scripts/run-tauri.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-virtual": "^3.13.26",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.513.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "impeccable": "^2.1.9",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "prettier": "^3.8.3",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.7"
  },
  "size-limit": [
    {
      "path": "dist/assets/*.js",
      "limit": "1.7 MB",
      "running": false
    },
    {
      "path": "dist/assets/*.css",
      "limit": "250 KB",
      "running": false
    }
  ]
}
